# Directory where job artifacts are stored.
# Default: ./jobs
JOBS_DIR=./jobs

# Whisper model name used for transcription.
# Examples: tiny, base, small, medium, large
# Default: large
WHISPER_MODEL=large

# Number of subtitle entries sent per translation batch.
# Default: 20
BATCH_SIZE=20

# OpenAI-compatible API base URL used for subtitle translation.
# Example: https://api.openai.com/v1
API_URL=https://api.openai.com/v1

# API key for the OpenAI-compatible backend.
WEBUI_API_KEY=your-api-key-here

# Chat/completions model name used for translation.
# Example: gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# Enable audio extraction endpoints.
# Accepted true values: 1, true, yes, on
# Default: true
ENABLE_AUDIO=true

# Enable transcription/conversion endpoints.
# Accepted true values: 1, true, yes, on
# Default: true
ENABLE_CONVERSION=true

# Bearer token required by the API.
# If omitted, a random token is generated at startup.
API_BEARER_TOKEN=replace-with-a-secure-token
