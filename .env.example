# Directory where job artifacts are stored.
# Default: ./jobs
JOBS_DIR=./jobs

# Whisper model name used for transcription.
# Examples: tiny, base, small, medium, large
# Default: large
WHISPER_MODEL=large

# Number of subtitle entries sent per translation batch.
# Default: 20
BATCH_SIZE=20

# OpenAI-compatible API base URL used for subtitle translation.
# Example: https://api.openai.com/v1
API_URL=https://api.openai.com/v1

# API key for the OpenAI-compatible backend.
WEBUI_API_KEY=your-api-key-here

# Chat/completions model name used for translation.
# Example: gpt-4o-mini
MODEL_NAME=gpt-4o-mini

# Enable audio extraction endpoints.
# Accepted true values: 1, true, yes, on
# Default: true
ENABLE_AUDIO=true

# Enable transcription/conversion endpoints.
# Accepted true values: 1, true, yes, on
# Default: true
ENABLE_CONVERSION=true

# Base URL for the optional segmentation service.
# When empty, Whisper transcribes the full WAV directly.
# Example: http://127.0.0.1:8001
SEGMENT_URL=

# Bearer token for the segmentation service.
SEGMENT_TOKEN=

# Polling interval in seconds while waiting for segmentation jobs.
# Default: 3
SEGMENT_POLL_INTERVAL=3

# Timeout in seconds for segmentation jobs.
# Use 0 to disable the timeout.
# Default: 300
SEGMENT_TIMEOUT=300

# Extra seconds added around segmentation boundaries when extracting portions.
# Default: 0.1
SEGMENT_DELTA=0.1

# Comma-separated source languages that should use language-specific
# segmentation endpoints.
# Example: en,it
SEGMENT_LANGS=

# Optional per-language segmentation overrides.
# These are used when the source language is listed in SEGMENT_LANGS.
# Examples:
# SEGMENT_URL_EN=http://127.0.0.1:8001
# SEGMENT_TOKEN_EN=replace-with-en-token
# SEGMENT_URL_IT=http://127.0.0.1:8002
# SEGMENT_TOKEN_IT=replace-with-it-token

# Bearer token required by the API.
# If omitted, a random token is generated at startup.
API_BEARER_TOKEN=replace-with-a-secure-token
